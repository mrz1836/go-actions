# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-actions
# Load Order: 90 (loaded near-last, overrides all earlier defaults)
#
# This file contains project-specific configuration that overrides defaults
# from the core (00), tool (10), and workflow (20) layers.
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 🪄 MAGE-X CONFIGURATION
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION
# ================================================================================================

# Coverage Provider Selection (codecov for this project)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions (aligned with codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/

# ================================================================================================
# 🛡️ SECURITY EXCLUSIONS
# ================================================================================================

# Nancy CVE Exclusions
NANCY_EXCLUDES=CVE-2023-42319,CVE-2026-26958

# Custom exclusions for Govulncheck/Magex vulnerability scanning
MAGE_X_CVE_EXCLUDES=GO-2026-5932
